{
  "name": "lopaka_chameleon",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc -b",
    "dev:web": "bun run --cwd apps/web dev",
    "dev:api": "bun run --cwd apps/api dev",
    "build:web": "bun run --cwd apps/web build",
    "build:api": "bun run --cwd apps/api build",
    "db:migrate:local": "wrangler d1 migrations apply lopaka_chameleon --local --config apps/api/wrangler.jsonc",
    "dev:api:cloudflare": "wrangler dev --config apps/api/wrangler.jsonc",
    "deploy:api": "wrangler deploy --config apps/api/wrangler.jsonc"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260706.1",
    "@types/three": "^0.185.0",
    "@vitejs/plugin-react": "^5.0.0",
    "jsdom": "^29.1.1",
    "typescript": "^5.9.0",
    "vite": "^7.0.0",
    "vitest": "^3.2.0",
    "wrangler": "^4.23.0"
  }
}
